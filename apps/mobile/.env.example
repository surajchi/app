# =============================================================================
# FinPulse MOBILE (Expo) environment.  Copy to apps/mobile/.env
#   cp apps/mobile/.env.example apps/mobile/.env
# Only EXPO_PUBLIC_* vars are exposed to the app bundle — never put secrets here.
# =============================================================================

# Base URL of the backend API (the Dockerized backend on the host).
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
