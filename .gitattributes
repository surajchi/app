# Normalize line endings to LF in the repo (consistent across Windows/macOS/Linux).
* text=auto eol=lf

# Shell scripts must stay LF.
*.sh text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
