# =============================================================================
# FinPulse BACKEND environment.  Copy to backend/.env and fill in.
#   cp backend/.env.example backend/.env
# backend/.env is gitignored. Never commit real secrets.
# Consumed by the api/worker/beat/postgres/opensearch/minio containers
# (docker-compose env_file) and by Django when run outside Docker.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
ENV=local
DJANGO_SETTINGS_MODULE=config.settings.local
DEBUG=true
SECRET_KEY=dev-insecure-change-me-please-generate-a-real-one-for-prod
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,api

# ---- PostgreSQL (+ TimescaleDB) ---------------------------------------------
POSTGRES_DB=finpulse
POSTGRES_USER=finpulse
POSTGRES_PASSWORD=finpulse
DATABASE_URL=postgres://finpulse:finpulse@postgres:5432/finpulse

# ---- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Channels (WebSocket) layer — separate Redis db.
CHANNELS_REDIS_URL=redis://redis:6379/3

# ---- JWT --------------------------------------------------------------------
# Blank RS256 keys -> dev falls back to HS256 (SECRET_KEY). RS256 required in prod.
#   openssl genrsa -out jwtRS256.key 2048
#   openssl rsa -in jwtRS256.key -pubout -out jwtRS256.key.pub
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_LIFETIME_MIN=15
REFRESH_TOKEN_LIFETIME_DAYS=30

# ---- CORS / CSRF ------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8081,http://localhost:3000

# ---- Email (Phase 2B) -------------------------------------------------------
# Dev: console backend prints emails to the api logs (no SMTP needed).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=FinPulse <no-reply@finpulse.app>
FRONTEND_URL=http://localhost:8081

# ---- Auth flows (Phase 2B) --------------------------------------------------
OTP_TTL_SECONDS=300
OTP_LENGTH=6
TWO_FACTOR_ISSUER=FinPulse
# OAuth — required only to use the provider live (endpoints exist without them).
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# ---- Market data (Phase 3) --------------------------------------------------
# "yahoo" = free REAL quotes/history (no API key) with synthetic fallback.
# "synthetic" = fully offline deterministic data (no network).
MARKET_DATA_PROVIDER=yahoo
MARKET_POLL_INTERVAL=15

# ---- Alerts (Phase 6B) ------------------------------------------------------
# How often the Celery beat evaluates price alert rules (seconds).
ALERT_EVAL_INTERVAL=30

# ---- Billing / Payments (Phase 9) -------------------------------------------
# "mock" is a free, keyless provider (approves any charge) for dev/CI. Swap for
# a real gateway adapter (e.g. stripe) in production.
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=
BILLING_CURRENCY=USD
# How often the Celery beat renews/expires subscriptions (seconds).
BILLING_RENEWAL_INTERVAL=3600

# ---- News (Phase 4) ---------------------------------------------------------
# "synthetic" needs no keys. Set "rss" + NEWS_RSS_FEEDS for real feeds.
NEWS_PROVIDER=synthetic
NEWS_POLL_INTERVAL=60
# Comma-separated RSS feed URLs (used when NEWS_PROVIDER=rss).
NEWS_RSS_FEEDS=
# Sentiment backend: "lexicon" (local, default) or "ai_service" (calls the AI svc).
NEWS_SENTIMENT_BACKEND=lexicon

# ---- AI service (Phase 5) ---------------------------------------------------
AI_SERVICE_URL=http://ai:8100
# Shared service-to-service token (blank = disabled in dev). Set the same value
# here and in the ai container to require it.
AI_SERVICE_TOKEN=

# ---- Object storage (MinIO) — used from Phase 5 -----------------------------
MINIO_ROOT_USER=finpulse
MINIO_ROOT_PASSWORD=finpulse-minio
MINIO_ENDPOINT=http://minio:9000

# ---- OpenSearch — used from Phase 4 -----------------------------------------
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=FinPulse-OS-2026!

# ---- Performance / rate limiting (Phase 10) ---------------------------------
# Persistent DB connections (seconds). DRF throttle rates by scope.
DB_CONN_MAX_AGE=60
THROTTLE_AUTH=20/min
THROTTLE_ANON=60/min
THROTTLE_USER=1000/min

# ---- Observability (optional) -----------------------------------------------
# Blank SENTRY_DSN disables error monitoring entirely (SDK not even imported).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
LOG_LEVEL=INFO
