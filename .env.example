# =============================================================================
# FinPulse — environment template.  Copy to `.env` and fill in.
#   cp .env.example .env
# `.env` is gitignored. Never commit real secrets.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
ENV=local
DJANGO_SETTINGS_MODULE=config.settings.local
DEBUG=true
# Generate a strong key for non-local envs, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-insecure-change-me-please-generate-a-real-one-for-prod
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,api

# ---- Database (PostgreSQL + TimescaleDB) ------------------------------------
# These three are consumed by the postgres container...
POSTGRES_DB=finpulse
POSTGRES_USER=finpulse
POSTGRES_PASSWORD=finpulse
# ...and this URL is consumed by Django. Host = the compose service name.
DATABASE_URL=postgres://finpulse:finpulse@postgres:5432/finpulse

# ---- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- JWT --------------------------------------------------------------------
# Leave the RS256 keys blank for local dev -> the app falls back to HS256
# signed with SECRET_KEY (multi-worker safe, zero setup).
# For prod (DEBUG=false) RS256 keys are REQUIRED. Generate with:
#   openssl genrsa -out jwtRS256.key 2048
#   openssl rsa -in jwtRS256.key -pubout -out jwtRS256.key.pub
# then paste PEM contents here (use literal \n for newlines on one line, or a quoted block).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_LIFETIME_MIN=15
REFRESH_TOKEN_LIFETIME_DAYS=30

# ---- CORS / CSRF ------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8081,http://localhost:3000

# ---- Object storage (MinIO) — used from Phase 5 -----------------------------
MINIO_ROOT_USER=finpulse
MINIO_ROOT_PASSWORD=finpulse-minio
MINIO_ENDPOINT=http://minio:9000

# ---- OpenSearch — used from Phase 4 -----------------------------------------
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=FinPulse-OS-2026!

# ---- Frontend (Expo) --------------------------------------------------------
# Public vars are exposed to the app bundle; never put secrets here.
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# ---- Observability (optional) -----------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO
